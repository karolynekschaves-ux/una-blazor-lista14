@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://avataaars.io/?avatarStyle=Circle&topType=LongHairBigHair&accessoriesType=Prescription02&hairColor=Brown&facialHairType=Blank&clotheType=Overall&clotheColor=Pink&eyeType=Wink&eyebrowType=UpDownNatural&mouthType=Smile&skinColor=Light
/>" class="rounded-circle mb-3"
                     width="120" />
                <h3>Karolyne Silva</h3>
                <p class="text-muted">Dev. Junior</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "Empresa de DevCodings",
            Cargo = "Estagio",
            Inicio = "2023", Fim = "Atual",
            Descricao = "Atuação no desenvolvimento aplicações em java, C# e Blazor."
        },
        new Experiencia {
            Empresa = "Levty",
            Cargo = "Trainee",
            Inicio = "2023", Fim = "2024",
            Descricao = "Criação de sites para soluções e suporte ao cliente."
        }
    };
}